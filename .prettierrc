{
    "tabWidth": 4,
    "useTabs": false,
    "overrides": [
        {
            "files": "*.md",
            "options": {
                "tabWidth": 2,
                "proseWrap": "never"
            }
        },
        {
            "files": "*.json",
            "options": {
                "tabWidth": 4
            }
        },
        {
            "files": ["*.css", "*.js"],
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
