{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/nuncaeslupus/research-buddy/schemas/document.schema.json",
    "title": "Research Buddy Document",
    "description": "Schema for Research Buddy input documents",
    "type": "object",
    "required": [
        "meta",
        "tabs"
    ],
    "properties": {
        "agent_guidelines": {
            "type": "object",
            "required": [
                "framework",
                "session_protocol",
                "project_specific"
            ],
            "properties": {
                "framework": {
                    "type": "object",
                    "description": "Universal, read-once rules. Never modified per-project.",
                    "properties": {
                        "about": {
                            "type": "string"
                        },
                        "document_navigation": {
                            "type": "string"
                        },
                        "content_format": {
                            "type": "string"
                        },
                        "cross_links": {
                            "type": "string"
                        },
                        "widget_library": {
                            "type": "object",
                            "additionalProperties": true
                        },
                        "versioning": {
                            "type": "object",
                            "additionalProperties": true
                        },
                        "update_targets": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        },
                        "failure_modes": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "html_generation": {
                            "type": "object",
                            "additionalProperties": true
                        },
                        "second_opinion_review": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "additionalProperties": true
                },
                "session_protocol": {
                    "type": "object",
                    "description": "Per-session procedure. Read at the start of every session.",
                    "properties": {
                        "detect_state": {
                            "type": "string"
                        },
                        "session_zero": {
                            "type": "object",
                            "additionalProperties": true
                        },
                        "standard_session": {
                            "type": "object",
                            "additionalProperties": true
                        },
                        "queue_empty": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    },
                    "additionalProperties": true
                },
                "project_specific": {
                    "type": "object",
                    "description": "Project-owned. Filled in session_zero. Do not modify framework or session_protocol.",
                    "properties": {
                        "_instructions": {
                            "type": "string"
                        },
                        "domain": {
                            "type": "string"
                        },
                        "research_language": {
                            "type": "string"
                        },
                        "deliverable_type": {
                            "type": "string"
                        },
                        "final_goal": {
                            "type": "string"
                        },
                        "timing": {
                            "type": [
                                "string",
                                "null"
                            ]
                        },
                        "key_locations": {
                            "type": "object",
                            "additionalProperties": true
                        },
                        "source_tiers": {
                            "type": "object",
                            "additionalProperties": true
                        },
                        "domain_constraints": {
                            "type": "object",
                            "additionalProperties": true
                        },
                        "validation_gate": {
                            "type": "string"
                        },
                        "update_rules": {
                            "type": "string"
                        },
                        "tabs_structure": {
                            "type": "string"
                        }
                    },
                    "additionalProperties": true
                }
            },
            "additionalProperties": true
        },
        "meta": {
            "type": "object",
            "required": [
                "version",
                "date"
            ],
            "properties": {
                "version": {
                    "type": "string"
                },
                "date": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                },
                "short_title": {
                    "type": "string"
                },
                "subtitle": {
                    "type": "string"
                },
                "file_name": {
                    "type": "string"
                },
                "title_page_section_title": {
                    "type": "string"
                },
                "phase": {
                    "type": "string"
                },
                "language": {
                    "oneOf": [
                        {
                            "type": "string",
                            "description": "Legacy: plain language label (e.g. 'English')."
                        },
                        {
                            "type": "object",
                            "required": [
                                "code"
                            ],
                            "properties": {
                                "code": {
                                    "type": "string",
                                    "description": "BCP-47 language code (e.g. 'en', 'es', 'zh')."
                                },
                                "label": {
                                    "type": "string",
                                    "description": "Human-readable language name (e.g. 'English')."
                                },
                                "note": {
                                    "type": "string",
                                    "description": "Enforcement instruction for agents."
                                }
                            }
                        }
                    ]
                },
                "research_buddy_version": {
                    "type": "string",
                    "description": "Version of Research Buddy that created or last updated this document. Required for schema and build script compatibility."
                },
                "ui_strings": {
                    "type": "object",
                    "description": "Translatable UI labels used in document content. Update in session_zero to match meta.language.",
                    "additionalProperties": {
                        "type": "string"
                    }
                }
            },
            "additionalProperties": true
        },
        "tabs": {
            "type": "array",
            "minItems": 1,
            "items": {
                "$ref": "#/$defs/tab"
            }
        },
        "changelog": {
            "$ref": "#/$defs/changelog"
        }
    },
    "additionalProperties": true,
    "$defs": {
        "tab": {
            "type": "object",
            "required": [
                "id",
                "label",
                "sections"
            ],
            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_-]*$"
                },
                "label": {
                    "type": "string"
                },
                "sections": {
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/$defs/section"
                    }
                }
            }
        },
        "section": {
            "type": "object",
            "properties": {
                "subtitle": {
                    "type": "string"
                },
                "agent_instruction": {
                    "type": "string"
                },
                "blocks": {
                    "type": "array",
                    "items": {
                        "$ref": "#/$defs/block"
                    }
                },
                "subsections": {
                    "type": "object",
                    "additionalProperties": {
                        "$ref": "#/$defs/section"
                    }
                }
            }
        },
        "block": {
            "type": "object",
            "required": [
                "type"
            ],
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "p",
                        "h3",
                        "h4",
                        "heading",
                        "paragraph",
                        "hr",
                        "ul",
                        "ol",
                        "code",
                        "callout",
                        "verdict",
                        "table",
                        "svg",
                        "usage_banner",
                        "agnostic_banner",
                        "cc_banner",
                        "phase_cards",
                        "card_grid",
                        "references"
                    ]
                },
                "agent_only": {
                    "type": "boolean"
                }
            },
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "p"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "md": {
                                "type": "string"
                            },
                            "style": {
                                "type": "string"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "h3"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "md": {
                                "type": "string"
                            },
                            "id": {
                                "type": "string"
                            },
                            "badge": {
                                "type": "string"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "h4"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "md": {
                                "type": "string"
                            },
                            "id": {
                                "type": "string"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "heading"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "content"
                        ],
                        "properties": {
                            "level": {
                                "type": "integer",
                                "enum": [
                                    3,
                                    4
                                ]
                            },
                            "content": {
                                "type": "string"
                            },
                            "id": {
                                "type": "string"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "paragraph"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "content"
                        ],
                        "properties": {
                            "content": {
                                "type": "string"
                            },
                            "style": {
                                "type": "string"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "code"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "text": {
                                "type": "string"
                            },
                            "lang": {
                                "type": "string"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "callout"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "md": {
                                "type": "string"
                            },
                            "variant": {
                                "type": "string",
                                "enum": [
                                    "blue",
                                    "green",
                                    "amber",
                                    "red",
                                    "purple"
                                ]
                            },
                            "title": {
                                "type": "string"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "verdict"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "md": {
                                "type": "string"
                            },
                            "badge": {
                                "type": "string"
                            },
                            "badge_text": {
                                "type": "string"
                            },
                            "label": {
                                "type": "string"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "table"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "headers": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "rows": {
                                "type": "array",
                                "items": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                }
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "ul"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "items": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "ol"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "items": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "svg"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "html": {
                                "type": "string"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "phase_cards"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "cards": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "phase": {
                                            "type": "string"
                                        },
                                        "title": {
                                            "type": "string"
                                        },
                                        "items": {
                                            "type": "array",
                                            "items": {
                                                "type": "string"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "card_grid"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "cols": {
                                "type": "integer",
                                "enum": [
                                    2,
                                    3
                                ]
                            },
                            "cards": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "title": {
                                            "type": "string"
                                        },
                                        "md": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "usage_banner"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "title": {
                                "type": "string"
                            },
                            "items": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "agnostic_banner"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "title": {
                                "type": "string"
                            },
                            "md": {
                                "type": "string"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "cc_banner"
                            }
                        }
                    },
                    "then": {
                        "properties": {
                            "title": {
                                "type": "string"
                            },
                            "md": {
                                "type": "string"
                            }
                        }
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "references"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "items"
                        ],
                        "properties": {
                            "items": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "required": [
                                        "text"
                                    ],
                                    "properties": {
                                        "version": {
                                            "type": "string"
                                        },
                                        "date": {
                                            "type": "string"
                                        },
                                        "text": {
                                            "type": "string"
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            ]
        },
        "changelog": {
            "type": "object",
            "required": [
                "entries"
            ],
            "properties": {
                "entries": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": [
                            "version",
                            "date",
                            "blocks"
                        ],
                        "properties": {
                            "version": {
                                "type": "string"
                            },
                            "id": {
                                "type": "string"
                            },
                            "date": {
                                "type": "string"
                            },
                            "current": {
                                "type": "boolean"
                            },
                            "blocks": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/$defs/block"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}