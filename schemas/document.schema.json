{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/nuncaeslupus/research-docs-generator/schemas/document.schema.json",
    "title": "Research Buddy Document",
    "description": "Schema for Research Buddy input documents",
    "type": "object",
    "required": ["meta", "tabs"],
    "properties": {
        "agent_guidelines": {
            "type": "object",
            "properties": {
                "structure_map": { "type": "string" },
                "surgical_update_protocol": { "type": "string" },
                "widget_library": { "type": ["string", "object"] }
            },
            "additionalProperties": true
        },
        "meta": {
            "type": "object",
            "required": ["version", "date"],
            "properties": {
                "version": { "type": "string" },
                "date": { "type": "string" },
                "title": { "type": "string" },
                "short_title": { "type": "string" },
                "subtitle": { "type": "string" },
                "title_page_section_title": { "type": "string" },
                "phase": { "type": "string" },
                "language": { "type": "string", "default": "English" }
            },
            "additionalProperties": true
        },
        "tabs": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/tab" }
        },
        "changelog": { "$ref": "#/$defs/changelog" }
    },
    "additionalProperties": true,
    "$defs": {
        "tab": {
            "type": "object",
            "required": ["id", "label", "sections"],
            "properties": {
                "id": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
                "label": { "type": "string" },
                "sections": {
                    "type": "object",
                    "additionalProperties": { "$ref": "#/$defs/section" }
                }
            }
        },
        "section": {
            "type": "object",
            "properties": {
                "subtitle": { "type": "string" },
                "agent_instruction": { "type": "string" },
                "blocks": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/block" }
                },
                "subsections": {
                    "type": "object",
                    "additionalProperties": { "$ref": "#/$defs/section" }
                }
            }
        },
        "block": {
            "type": "object",
            "required": ["type"],
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "p", "h3", "h4", "heading", "paragraph", "hr",
                        "ul", "ol", "code", "callout", "verdict", "table",
                        "svg", "usage_banner", "agnostic_banner", "cc_banner",
                        "phase_cards", "card_grid", "references"
                    ]
                },
                "agent_only": { "type": "boolean" }
            },
            "allOf": [
                {
                    "if": { "properties": { "type": { "const": "p" } } },
                    "then": { "properties": { "md": { "type": "string" }, "style": { "type": "string" } } }
                },
                {
                    "if": { "properties": { "type": { "const": "h3" } } },
                    "then": { "properties": { "md": { "type": "string" }, "id": { "type": "string" }, "badge": { "type": "string" } } }
                },
                {
                    "if": { "properties": { "type": { "const": "h4" } } },
                    "then": { "properties": { "md": { "type": "string" }, "id": { "type": "string" } } }
                },
                {
                    "if": { "properties": { "type": { "const": "heading" } } },
                    "then": {
                        "required": ["content"],
                        "properties": {
                            "level": { "type": "integer", "enum": [3, 4] },
                            "content": { "type": "string" },
                            "id": { "type": "string" }
                        }
                    }
                },
                {
                    "if": { "properties": { "type": { "const": "paragraph" } } },
                    "then": {
                        "required": ["content"],
                        "properties": { "content": { "type": "string" }, "style": { "type": "string" } }
                    }
                },
                {
                    "if": { "properties": { "type": { "const": "code" } } },
                    "then": {
                        "properties": { "text": { "type": "string" }, "lang": { "type": "string" } }
                    }
                },
                {
                    "if": { "properties": { "type": { "const": "callout" } } },
                    "then": {
                        "properties": {
                            "md": { "type": "string" },
                            "variant": { "type": "string", "enum": ["blue", "green", "amber", "red", "purple"] },
                            "title": { "type": "string" }
                        }
                    }
                },
                {
                    "if": { "properties": { "type": { "const": "verdict" } } },
                    "then": {
                        "properties": {
                            "md": { "type": "string" },
                            "badge": { "type": "string" },
                            "badge_text": { "type": "string" },
                            "label": { "type": "string" }
                        }
                    }
                },
                {
                    "if": { "properties": { "type": { "const": "table" } } },
                    "then": {
                        "properties": {
                            "headers": { "type": "array", "items": { "type": "string" } },
                            "rows": { "type": "array", "items": { "type": "array", "items": { "type": "string" } } }
                        }
                    }
                },
                {
                    "if": { "properties": { "type": { "const": "ul" } } },
                    "then": { "properties": { "items": { "type": "array", "items": { "type": "string" } } } }
                },
                {
                    "if": { "properties": { "type": { "const": "ol" } } },
                    "then": { "properties": { "items": { "type": "array", "items": { "type": "string" } } } }
                },
                {
                    "if": { "properties": { "type": { "const": "svg" } } },
                    "then": { "properties": { "html": { "type": "string" } } }
                },
                {
                    "if": { "properties": { "type": { "const": "phase_cards" } } },
                    "then": {
                        "properties": {
                            "cards": { "type": "array", "items": {
                                "type": "object",
                                "properties": {
                                    "phase": { "type": "string" },
                                    "title": { "type": "string" },
                                    "items": { "type": "array", "items": { "type": "string" } }
                                }
                            }}
                        }
                    }
                },
                {
                    "if": { "properties": { "type": { "const": "card_grid" } } },
                    "then": {
                        "properties": {
                            "cols": { "type": "integer", "enum": [2, 3] },
                            "cards": { "type": "array", "items": {
                                "type": "object",
                                "properties": { "title": { "type": "string" }, "md": { "type": "string" } }
                            }}
                        }
                    }
                },
                {
                    "if": { "properties": { "type": { "const": "references" } } },
                    "then": {
                        "required": ["items"],
                        "properties": {
                            "items": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "required": ["text"],
                                    "properties": {
                                        "text": { "type": "string" },
                                        "version": { "type": "string" },
                                        "date": { "type": "string" }
                                    }
                                }
                            }
                        }
                    }
                }
            ]
        },
        "changelog": {
            "type": "object",
            "properties": {
                "agent_instruction": { "type": "string" },
                "entries": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/changelogEntry" }
                },
                "protocol_blocks": {
                    "type": "array",
                    "items": { "$ref": "#/$defs/block" }
                }
            }
        },
        "changelogEntry": {
            "type": "object",
            "required": ["version"],
            "properties": {
                "id": { "type": "string", "pattern": "^cl-v\\d+$" },
                "version": { "type": "string" },
                "current": { "type": "boolean" },
                "paragraphs": { "type": "array", "items": { "type": "string" } },
                "title": { "type": "string" },
                "items": { "type": "array", "items": { "type": "string" } }
            }
        }
    }
}
